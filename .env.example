# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.0-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.0-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-thinking-exp
# GEMINI_MODEL=gemini-2.0-flash

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration

# ── Autopilot (this fork) ─────────────────────────────────────────────────────
# Apify token for LinkedIn job scanning
# Get from https://console.apify.com/settings/integrations
APIFY_API_TOKEN=apify_api_your_token_here

# ── LLM Provider for Autopilot Pre-filter ───────────────────────────────────
# Pick one provider. Defaults to anthropic/claude-haiku-4-5 if unset.
#
# Supported providers: anthropic, openai, minimax, deepseek, together, groq,
#   mistral, custom
#
# LLM_PROVIDER=anthropic               → uses ANTHROPIC_API_KEY (native SDK, supports prompt caching)
# LLM_PROVIDER=minimax                 → uses MINIMAX_API_KEY  (OpenAI-compatible, https://api.minimaxi.com/v1)
# LLM_PROVIDER=openai                  → uses OPENAI_API_KEY
# LLM_PROVIDER=deepseek                → uses DEEPSEEK_API_KEY
# LLM_PROVIDER=custom + LLM_BASE_URL   → any OpenAI-compatible endpoint
#
# LLM_MODEL overrides the per-provider default. LLM_API_KEY overrides the
# provider-specific env var (e.g. ANTHROPIC_API_KEY).

# ── Example: MiniMax via Anthropic-compat endpoint (RECOMMENDED) ───────────
# Simplest setup — the Anthropic SDK respects ANTHROPIC_BASE_URL, so no code
# changes are needed. Prompt caching continues to work (if the proxy forwards it).
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
ANTHROPIC_API_KEY=your_minimax_api_key_here
LLM_MODEL=MiniMax-M2.7

# ── Example: MiniMax via OpenAI-compat endpoint (alternative) ──────────────
# Use this only if the Anthropic-compat proxy isn't available. Loses Anthropic's
# prompt caching, uses OpenAI SDK internally via lib/llm.mjs.
# LLM_PROVIDER=minimax
# MINIMAX_API_KEY=your_minimax_api_key_here
# LLM_MODEL=MiniMax-M1         # optional; defaults to MiniMax-M1

# ── Example: Anthropic (production) ────────────────────────────────────────
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-your_key_here
# LLM_MODEL=claude-haiku-4-5-20251001   # optional; defaults to Haiku 4.5

# ── Example: Custom OpenAI-compatible endpoint ─────────────────────────────
# LLM_PROVIDER=custom
# LLM_BASE_URL=https://api.example.com/v1
# LLM_API_KEY=your_key
# LLM_MODEL=your-model-name

# Auto-apply CAPSOLVER integration (optional). Without this, CAPTCHA-gated
# application forms get marked Failed. Free tier $0.50, pay-as-you-go.
# See https://capsolver.com/
CAPSOLVER_API_KEY=
